#!/bin/zsh
set -euo pipefail

APP_BIN_DIR="$(cd "$(dirname "$0")" && pwd)"
APP_CONTENTS_DIR="$(cd "$APP_BIN_DIR/.." && pwd)"
RESOURCE_DIR="$APP_CONTENTS_DIR/Resources"
LAUNCH_PATH="$RESOURCE_DIR/launch.command"

exec /usr/bin/osascript \
  -e 'on run argv' \
  -e 'tell application "Terminal"' \
  -e 'activate' \
  -e 'do script quoted form of (item 1 of argv)' \
  -e 'end tell' \
  -e 'end run' \
  "$LAUNCH_PATH"
